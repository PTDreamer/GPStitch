<layout>
  <composite name="date_and_time" x="260" y="30">
    <component type="datetime" format="%d/%m/%Y" size="16" align="right" />
    <component type="datetime" y="24" format="%H:%M:%S" size="32" align="right" />
  </composite>
  <translate x="16" y="16">
    <translate>
      <component type="icon" file="mountain.png" size="48" />
      <component type="text" x="65" size="16">ALT (m)</component>
      <component type="metric" x="55" y="20" align="left" metric="alt" dp="1" size="26" />
    </translate>
    <translate y="60">
      <component type="icon" file="slope-triangle.png" size="48" />
      <component type="text" x="65" size="16">SLP (%)</component>
      <component type="metric" x="70" y="20" align="left" metric="gradient" dp="1" size="26" />
    </translate>
  </translate>
  <translate x="16" y="160">
    <translate>
      <component type="text" size="16" rgb="255,200,0">RPM</component>
      <component type="metric" y="20" metric="engine_speed" dp="0" size="32" rgb="255,200,0" />
    </translate>
    <translate y="60">
      <component type="text" size="16" rgb="0,200,255">LEAN (mdeg)</component>
      <component type="metric" y="20" metric="lean_angle" dp="0" size="32" rgb="0,200,255" />
    </translate>
    <translate y="240">
      <component type="text" size="16" rgb="0,200,255">PITCH</component>
    </translate>
    <translate y="400">
      <component type="text" size="16" rgb="255,100,100">INTAKE TEMP</component>
      <component type="metric" y="20" metric="intake_air_temp" dp="1" size="32" rgb="255,100,100" />
    </translate>
    <translate y="460">
      <component type="text" size="16" rgb="100,255,100">MAF (mg/str)</component>
      <component type="metric" y="20" metric="mass_air_flow" dp="2" size="32" rgb="100,255,100" />
    </translate>
  </translate>
  <translate y="690">
    <component type="msi" metric="speed" textsize="16" needle="0" units="kph" />
    <translate x="128" y="90">
      <component type="metric" metric="speed" units="kph" dp="0" size="66" align="centre" />
    </translate>
    <translate x="128" y="220">
      <component type="text" size="18" align="centre">km/h</component>
    </translate>
    <translate y="260">
      <component type="bar" width="128" min="-3" max="0" height="40" metric="accl" outline-width="2" bar="255,157,157" h-neg="255,157,157" h-pos="255,157,157" zero="0,0,0,0" />
      <component type="text" x="63" y="11" size="16" align="centre">BRAKE</component>
      <translate x="127">
        <component type="bar" width="128" min="0" max="3" height="40" metric="accl" outline-width="2" bar="157,157,255" h-neg="157,157,255" h-pos="157,157,255" zero="0,0,0,0" />
        <component type="text" x="63" y="11" size="16" align="centre">THROTTLE</component>
      </translate>
    </translate>
  </translate>
  <translate x="1632" y="16">
    <frame width="256" opacity="0.6" height="256" cr="20" fo="20">
      <component type="moving_map" name="moving_map" size="256" zoom="15" />
    </frame>
    <frame y="276" width="256" opacity="0.6" height="256" cr="20" fo="20">
      <component type="moving_journey_map" size="256" zoom="14" />
    </frame>
  </translate>
  <component type="chart" name="chart" x="7" y="1010" samples="256" metric="speed" units="kph" fill="0,191,255,128" bg="0,0,0,128" values="false" />
  <translate x="1637" y="567">
    <component type="dirtbike" size="250" metric="pitch_angle" file="dirtbike_back.png" max_angle="45" colour="245,239,239" milidegrees="false" />
  </translate>
  <translate x="1637" y="828">
    <component type="dirtbike_lean" size="250" metric="lean_angle" file="dirtbike_side.png" max_angle="45" colour="245,239,239" milidegrees="false" />
  </translate>
  <component type="metric" x="884" y="242" metric="accl" units="G" dp="1" size="16" rgb="255,255,255" outline="0,0,0" outline_width="2" align="left" />
  <component type="metric" x="1045" y="392" metric="accl.x" units="G" dp="1" size="16" rgb="255,255,255" outline="0,0,0" outline_width="2" align="left" />
</layout>
