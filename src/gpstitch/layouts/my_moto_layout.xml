<layout>
    <!-- Top-left: Date/Time -->
    <composite x="260" y="30" name="date_and_time">
        <component type="datetime" x="0" y="0" format="%d/%m/%Y" size="16" align="right"/>
        <component type="datetime" x="0" y="24" format="%H:%M:%S" size="32" align="right"/>
    </composite>

    <!-- Top-left: Altitude & Slope -->
    <translate x="16" y="16">
        <translate y="0">
            <component type="icon" x="0" file="mountain.png" size="48"/>
            <component type="text" x="65" size="16">ALT (m)</component>
            <component type="metric" x="55" y="20" align="left" metric="alt" dp="1" size="26"/>
        </translate>
        <translate y="60">
            <component type="icon" x="0" file="slope-triangle.png" size="48"/>
            <component type="text" x="65" size="16">SLP (%)</component>
            <component type="metric" x="70" y="20" align="left" metric="gradient" dp="1" size="26"/>
        </translate>
    </translate>

    <!-- Top-right: KTM FIT Custom Fields -->
    <translate x="16" y="160">
        <!-- Engine Speed -->
        <translate y="0">
            <component type="text" x="0" y="0" size="16" rgb="255,200,0">RPM</component>
            <component type="metric" x="0" y="20" metric="engine_speed" dp="0" size="32" rgb="255,200,0"/>
        </translate>
        <!-- Lean Angle -->
        <translate y="60">
            <component type="text" x="0" y="0" size="16" rgb="0,200,255">LEAN (mdeg)</component>
            <component type="metric" x="0" y="20" metric="lean_angle" dp="0" size="32" rgb="0,200,255"/>
            <component type="dirtbike" x="0" y="60" metric="lean_angle" file="dirtbike_side.png" size="256" max_angle="45"/>
        </translate>
        <!-- Pitch Angle -->
        <translate y="240">
            <component type="text" x="0" y="0" size="16" rgb="0,200,255">PITCH</component>
            <component type="dirtbike" x="0" y="20" metric="pitch_angle" file="dirtbike_back.png" size="256" max_angle="45" colour="50,60,90,128"/>
        </translate>
        <!-- Intake Air Temp -->
        <translate y="400">
            <component type="text" x="0" y="0" size="16" rgb="255,100,100">INTAKE TEMP</component>
            <component type="metric" x="0" y="20" metric="intake_air_temp" dp="1" size="32" rgb="255,100,100"/>
        </translate>
        <!-- Mass Air Flow -->
        <translate y="460">
            <component type="text" x="0" y="0" size="16" rgb="100,255,100">MAF (mg/str)</component>
            <component type="metric" x="0" y="20" metric="mass_air_flow" dp="2" size="32" rgb="100,255,100"/>
        </translate>
    </translate>

    <!-- Bottom-left: Speed gauge -->
    <translate x="0" y="690">
        <component type="msi" metric="speed" textsize="16" needle="0" units="kph"/>
        <translate x="128" y="90">
            <component type="metric" metric="speed" units="kph" dp="0" size="66" align="centre"/>
        </translate>
        <translate x="128" y="220">
            <component type="text" size="18" align="centre">km/h</component>
        </translate>

        <translate x="0" y="260">
            <component type="bar" width="128" min="-3" max="0" height="40" metric="accel" outline-width="2" bar="255,157,157" h-neg="255,157,157" h-pos="255,157,157" zero="0,0,0,0"/>
            <component x="63" y="11" type="text" size="16" align="centre">BRAKE</component>
            <translate x="127">
                <component type="bar" width="128" min="0" max="3" height="40" metric="accel" outline-width="2" bar="157,157,255" h-neg="157,157,255" h-pos="157,157,255" zero="0,0,0,0"/>
                <component x="63" y="11" type="text" size="16" align="centre">THROTTLE</component>
            </translate>
        </translate>
    </translate>

    <!-- Right side: Maps -->
    <translate x="1632" y="16">
        <frame width="256" opacity="0.6" height="256" cr="20" fo="20">
            <component type="moving_map" name="moving_map" size="256" zoom="15"/>
        </frame>
        <frame y="276" width="256" opacity="0.6" height="256" cr="20" fo="20">
            <component type="moving_journey_map" size="256" zoom="14"/>
        </frame>
    </translate>

    <!-- Bottom: Speed chart -->
    <component x="7" y="1010" samples="256" type="chart" name="chart" metric="speed" units="kph" fill="0,191,255,128" bg="0,0,0,128" values="false"/>
</layout>
